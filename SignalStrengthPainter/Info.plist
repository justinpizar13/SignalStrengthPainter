<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleDisplayName</key>
    <string>WiFi Buddy</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.1</string>
    <key>CFBundleVersion</key>
    <string>2</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <key>UILaunchScreen</key>
    <dict/>
    <!--
      App Transport Security: defaults apply (HTTPS only). All network
      calls in the app go to https://speed.cloudflare.com and TCP pings
      to public DNS resolvers; no plaintext HTTP is used.
    -->
    <!--
      Export compliance. The app uses only Apple-provided TLS (HTTPS for
      Cloudflare speed tests, standard iOS network stack everywhere else)
      and no proprietary cryptography, so it qualifies for the Category 5
      Part 2 exemption. Declaring this here skips the export-compliance
      questionnaire on every TestFlight upload.
    -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!--
      Orientation: portrait only. The AR survey canvas
      (SignalMapViewModel.projectToMap) assumes a portrait-up device so
      the x/z floor projection lines up with the rendered map; allowing
      mid-walk rotation would visibly skew the heat trail. iPhone-only
      build, so no ~ipad override is needed.
    -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <!--
      AR + full-screen posture. Stage Manager / Split View break
      ARWorldTrackingConfiguration's camera pipeline, so the survey tab
      requires a full-screen window.
    -->
    <key>UIRequiresFullScreen</key>
    <true/>
    <!--
      Device capability: the app requires ARKit world tracking (used by
      the Survey tab's AR positioning). Listing it here prevents the app
      from appearing on non-AR-capable hardware in the App Store, which
      is the right filter for a feature we can't fall back from.
    -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arkit</string>
        <string>wifi</string>
    </array>
    <key>NSMotionUsageDescription</key>
    <string>This app uses motion data to draw your walked signal map path.</string>
    <key>NSCameraUsageDescription</key>
    <string>This app uses the camera for AR-based indoor positioning and map anchoring.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>This app checks local network quality to color your signal map.</string>
    <!--
      Bonjour service types the app browses. iOS 14+ requires every service
      type passed to NWBrowser / NetServiceBrowser to be declared here, or
      `DNSServiceBrowse` fails immediately with `NoAuth(-65555)` and no
      results are returned. Without this key, device discovery silently
      falls back to the TCP/MAC layers and many devices end up unlabeled.
      Keep this list in sync with `NetworkScanner.bonjourServiceTypes`.
    -->
    <key>NSBonjourServices</key>
    <array>
        <string>_http._tcp</string>
        <string>_airplay._tcp</string>
        <string>_raop._tcp</string>
        <string>_smb._tcp</string>
        <string>_afpovertcp._tcp</string>
        <string>_ipp._tcp</string>
        <string>_printer._tcp</string>
        <string>_googlecast._tcp</string>
        <string>_spotify-connect._tcp</string>
        <string>_homekit._tcp</string>
        <string>_hap._tcp</string>
        <string>_device-info._tcp</string>
        <string>_companion-link._tcp</string>
        <string>_sleep-proxy._udp</string>
        <string>_rdlink._tcp</string>
        <string>_rfb._tcp</string>
        <string>_amzn-wplay._tcp</string>
        <string>_apple-mobdev2._tcp</string>
        <string>_touch-able._tcp</string>
    </array>
</dict>
</plist>
