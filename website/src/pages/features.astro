---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import AppStoreButton from "@/components/AppStoreButton.astro";
import { SITE } from "@/lib/site";

const title = "Features — How WiFi Buddy works";
const description =
  "WiFi Buddy paints a real-time Wi-Fi heatmap as you walk your home, then turns it into a graded report telling you exactly where to fix your dead zones first.";
---

<BaseLayout title={title} description={description}>
  <Section pad="lg">
    <p class="text-sm uppercase tracking-wider text-[--color-signal-blue]">Features</p>
    <h1 class="mt-2 font-display text-4xl sm:text-5xl font-extrabold tracking-tight leading-tight">
      Walk your home. Get a clear Wi-Fi report. Know what to fix.
    </h1>
    <p class="mt-5 max-w-3xl text-lg text-[--color-fg-muted]">
      WiFi Buddy is built around a single idea: a number on a screen
      tells you nothing about <em>where</em> your signal dies. Painting
      your signal across the whole space turns a fuzzy "Wi-Fi feels
      slow" complaint into a list of specific rooms and specific fixes.
    </p>
  </Section>

  <Section pad="md">
    <div class="grid gap-10 md:grid-cols-5" data-reveal-stagger>
      <div class="md:col-span-3">
        <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
          Walk-and-paint Wi-Fi survey
        </h2>
        <p class="mt-3 text-[--color-fg-muted]">
          Tap your starting point on the floor plan, hit
          <em>Start Survey</em>, and walk. As you move, WiFi Buddy paints
          your signal onto the map — green for excellent, amber for
          fair, red for a dead zone. No extra hardware. No router login.
          Just your iPhone.
        </p>
        <p class="mt-3 text-[--color-fg-muted]">
          Need to correct course after a long walk? Tap
          <em>Re-anchor Here</em> and tap the spot on the map where you
          actually are — WiFi Buddy figures out the rest, so you don't
          have to tell the app "which way is forward".
        </p>
        <p class="mt-3 text-[--color-fg-muted]">
          When you stop, the trail and heatmap stay on the map for
          review. Pinch to zoom, drag to pan, and tap any waypoint to
          see what your signal looked like at that exact step.
        </p>
      </div>
      <aside class="md:col-span-2 card p-6">
        <p class="text-xs uppercase tracking-wider text-[--color-fg-dim]">Designed for indoors</p>
        <h3 class="mt-2 font-display text-lg font-semibold">Accurate room-scale tracking</h3>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          Most "step counter" apps lose their place indoors — magnetic
          headings drift around metal and electronics, and step counts
          are too coarse for room-by-room detail. WiFi Buddy uses your
          iPhone's camera-assisted motion tracking for stable,
          room-scale accuracy.
        </p>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          The camera feed is used by your iPhone only. It is never
          recorded, screenshotted, or sent anywhere.
        </p>
      </aside>
    </div>
  </Section>

  <Section pad="md">
    <div data-reveal>
      <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
        A real report, not just a heatmap
      </h2>
      <p class="mt-3 max-w-3xl text-[--color-fg-muted]">
        Most heatmap apps stop at colored dots. When you finish a survey,
        WiFi Buddy turns your walk into a graded report you can actually
        act on. Same walk in, same answers out — every time.
      </p>
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3" data-reveal-stagger>
      <div class="card p-6">
        <p class="text-xs uppercase tracking-wider text-[--color-fg-dim]">Step 1</p>
        <h3 class="mt-2 font-display text-lg font-semibold">Score &amp; grade</h3>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          A clear A–F grade for your coverage, plus a one-sentence
          headline so you understand what you're looking at without
          digging through numbers.
        </p>
      </div>
      <div class="card p-6">
        <p class="text-xs uppercase tracking-wider text-[--color-fg-dim]">Step 2</p>
        <h3 class="mt-2 font-display text-lg font-semibold">Find dead zones</h3>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          Bad spots get grouped together by area — "2 dead zones (master
          closet, back patio)" instead of an ambiguous fog of red dots
          across the map.
        </p>
      </div>
      <div class="card p-6">
        <p class="text-xs uppercase tracking-wider text-[--color-fg-dim]">Step 3</p>
        <h3 class="mt-2 font-display text-lg font-semibold">Tell you what to do</h3>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          A tailored "what to do next" list — mesh, extender,
          reposition, channel change, or a 5 GHz switch — based on the
          specific shape of your problem, not a generic checklist.
        </p>
      </div>
    </div>

    <div class="mt-10 card p-6 md:p-8" data-reveal>
      <h3 class="font-display text-xl font-bold">What's in your report</h3>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2 text-sm text-[--color-fg-muted]">
        <li>
          <strong class="text-[--color-fg]">Coverage breakdown.</strong> An at-a-glance look
          at how much of your home has excellent, fair, and poor signal.
        </li>
        <li>
          <strong class="text-[--color-fg]">Dead-zone count.</strong> Each weak spot
          is called out by location and severity, with the worst zone
          highlighted.
        </li>
        <li>
          <strong class="text-[--color-fg]">The video-call test.</strong> WiFi Buddy
          catches the rooms where your signal mostly feels fine but
          occasionally drops calls — the kind of problem averages miss.
        </li>
        <li>
          <strong class="text-[--color-fg]">Stability check.</strong> Calls out rooms
          where your signal is unstable enough that small movements
          change how it feels.
        </li>
        <li>
          <strong class="text-[--color-fg]">Router direction hint.</strong> If your
          walk reveals a clear pattern, WiFi Buddy tells you which way
          your router is and whether moving toward or away from it
          helps.
        </li>
        <li>
          <strong class="text-[--color-fg]">What to do next.</strong> Concrete
          recommendations — mesh vs. reposition vs. channel change —
          tailored to your specific results.
        </li>
      </ul>
    </div>
  </Section>

  <Section pad="md">
    <div class="grid gap-8 md:grid-cols-2" data-reveal-stagger>
      <div>
        <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
          A speed test you can trust
        </h2>
        <p class="mt-3 text-[--color-fg-muted]">
          Real download, upload, ping, and jitter — measured the way
          your apps actually use your connection, not with the number
          tricks ISP apps use to make their own service look fast. Plus
          a simple post-test rating that tells you what your connection
          is good for: streaming, gaming, video calls, home office, or
          basic browsing.
        </p>
      </div>
      <div>
        <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
          A clear view of your network
        </h2>
        <p class="mt-3 text-[--color-fg-muted]">
          A simple ISP → Router → Device picture, with a live health
          check on each hop. One glance tells you whether the slowdown
          is your provider, your router, or the device you're holding —
          so you stop blaming the wrong thing.
        </p>
      </div>
    </div>
  </Section>

  <Section pad="md">
    <div class="card p-8 md:p-10" data-reveal>
      <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
        Klaus, your friendly Wi-Fi sidekick
      </h2>
      <p class="mt-3 max-w-3xl text-[--color-fg-muted]">
        Klaus is a pixel-art assistant living on the Signal tab. Ask him
        anything about your home Wi-Fi — coverage, gaming, streaming,
        security, mesh upgrades, port forwarding, or any of the dozens
        of other questions people actually have. You'll get a clear,
        plain-English answer you can use.
      </p>
      <p class="mt-3 max-w-3xl text-[--color-fg-muted]">
        Free users get a question to try. Pro unlocks unlimited chat.
      </p>
    </div>
  </Section>

  <Section pad="md">
    <div class="card p-8 md:p-10 flex flex-col items-start gap-4" data-reveal>
      <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
        Try it on your own home.
      </h2>
      <p class="text-[--color-fg-muted]">
        Free Speed, Signal &amp; Devices tabs. WiFi Buddy Pro is
        <strong class="text-[--color-fg]">{SITE.pricing.annual}/year</strong> with a
        {SITE.pricing.trialDays}-day free trial.
      </p>
      <AppStoreButton size="lg" class="cta-press" />
    </div>
  </Section>
</BaseLayout>
