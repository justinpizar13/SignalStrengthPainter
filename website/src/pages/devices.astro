---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import AppStoreButton from "@/components/AppStoreButton.astro";

const title = "See every device on your Wi-Fi";
const description =
  "WiFi Buddy automatically names every gadget on your home Wi-Fi — phones, TVs, speakers, lights, IoT cameras, and more — without making you log into your router.";

// Article schema for the AI overview / Knowledge Panel.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: title,
  description,
  author: {
    "@type": "Organization",
    name: "WiFi Buddy",
  },
  about: [
    "Home Wi-Fi devices",
    "Network scanning",
    "Smart home",
    "MAC address randomization",
    "Trusted devices",
  ],
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <Section pad="lg">
    <p class="text-sm uppercase tracking-wider text-[--color-signal-orange]">Devices</p>
    <h1 class="mt-2 font-display text-4xl sm:text-5xl font-extrabold tracking-tight leading-tight">
      Know what's on your Wi-Fi.
    </h1>
    <p class="mt-5 max-w-3xl text-lg text-[--color-fg-muted]">
      "Find unknown devices on my home Wi-Fi" sounds simple. In practice,
      modern smart-home gadgets, privacy features, and quiet IoT devices
      make it surprisingly hard to put a friendly name next to every
      device. WiFi Buddy does the work for you — and you never have to
      log into your router.
    </p>
  </Section>

  <Section pad="md">
    <div class="grid gap-4 md:grid-cols-3" data-reveal-stagger>
      <div class="card p-6">
        <p class="text-xs uppercase tracking-wider text-[--color-signal-blue]">What you see</p>
        <h2 class="mt-2 font-display text-lg font-semibold">A friendly list, not a list of IPs</h2>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          WiFi Buddy turns the cryptic numbers most network apps show
          into a clean list of recognizable names — "Living Room Roku",
          "Justin's iPhone", "Hue Bridge" — with a type icon for each
          one.
        </p>
      </div>
      <div class="card p-6">
        <p class="text-xs uppercase tracking-wider text-[--color-signal-blue]">Why it works</p>
        <h2 class="mt-2 font-display text-lg font-semibold">Built for real homes</h2>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          Smart speakers, streaming sticks, printers, security cameras,
          smart lights, game consoles, and computers — WiFi Buddy is
          tuned to recognize the kinds of devices people actually have
          in their homes.
        </p>
      </div>
      <div class="card p-6">
        <p class="text-xs uppercase tracking-wider text-[--color-signal-blue]">No router login</p>
        <h2 class="mt-2 font-display text-lg font-semibold">Just open the app</h2>
        <p class="mt-2 text-sm text-[--color-fg-muted]">
          Tap Scan and you're done. No router admin password, no app
          install on every device, no setup wizard — just a clear
          picture of who's on your network in a few seconds.
        </p>
      </div>
    </div>
  </Section>

  <Section pad="md">
    <div class="grid gap-8 md:grid-cols-2" data-reveal-stagger>
      <div>
        <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
          Modern privacy features, handled.
        </h2>
        <p class="mt-3 text-[--color-fg-muted]">
          Modern phones rotate their network identity for privacy —
          which means the same phone can appear as a different "device"
          every time it reconnects. WiFi Buddy recognizes this and
          labels those devices clearly, so you don't get spooked by
          your own phone reappearing under a new name. Read more in our
          guide to <a href="/blog/mac-randomization-ios">MAC randomization on iOS</a>.
        </p>
      </div>
      <div>
        <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
          Trust devices. Get alerts.
        </h2>
        <p class="mt-3 text-[--color-fg-muted]">
          Mark the devices you recognize as <em>trusted</em>. The next
          time a brand new device joins your Wi-Fi, WiFi Buddy will
          quietly let you know — "New device on Wi-Fi: Roku Living
          Room". When several new devices show up at once, you get a
          single summary instead of a flurry of alerts.
        </p>
      </div>
    </div>
  </Section>

  <Section pad="md">
    <div class="card p-8 md:p-10 flex flex-col items-start gap-4" data-reveal>
      <h2 class="font-display text-2xl sm:text-3xl font-bold tracking-tight">
        See who's on your Wi-Fi.
      </h2>
      <p class="text-[--color-fg-muted]">
        Free on the Devices tab — no subscription required.
      </p>
      <AppStoreButton size="lg" class="cta-press" />
    </div>
  </Section>
</BaseLayout>
