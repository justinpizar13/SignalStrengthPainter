---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/Section.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("legal", "terms");
if (!entry) {
  throw new Error("Terms markdown missing — did sync-legal.mjs run?");
}
const { Content } = await render(entry);

const title = "Terms of Use";
const description =
  "WiFi Buddy's terms of use, including subscription billing terms, the acceptable-use policy, and limitation of liability.";
---

<BaseLayout title={title} description={description}>
  <Section pad="md" width="narrow">
    <article class="prose">
      <Content />
    </article>
  </Section>
</BaseLayout>
