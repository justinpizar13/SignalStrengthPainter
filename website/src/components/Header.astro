---
import Logo from "./Logo.astro";
import { PRIMARY_NAV, SITE } from "@/lib/site";

const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
function isActive(href: string): boolean {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<header class="border-b border-[--color-border] bg-[--color-bg]/85 backdrop-blur-md sticky top-0 z-40 transition-colors">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
    <a
      href="/"
      class="inline-flex items-center gap-3 transition hover:opacity-90"
      aria-label={`${SITE.name} — home`}
    >
      <Logo size={36} withTile />
      <span class="font-display text-lg font-bold tracking-tight">
        {SITE.name}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
      {PRIMARY_NAV.map((item) => (
        <a
          href={item.href}
          class={`nav-link rounded-lg px-3 py-2 text-sm font-medium transition ${
            isActive(item.href)
              ? "is-active text-[--color-fg] bg-white/5"
              : "text-[--color-fg-muted] hover:text-[--color-fg] hover:bg-white/5"
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={SITE.appStoreUrl}
      rel="noopener"
      class="cta-press hidden sm:inline-flex items-center gap-2 rounded-lg bg-white px-3.5 h-9 text-sm font-semibold text-black hover:bg-white/90"
    >
      Get the app
    </a>
  </div>
</header>
